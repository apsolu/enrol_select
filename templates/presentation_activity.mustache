{{!
    @template enrol_select/presentation_activity

    Template Moodle pour la page de présentation d'une activité.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * courses
        * url
        * description
        * courses
            * site
            * sport
            * generic_name
            * weekday
            * starttime
            * endtime
            * area
            * location
            * skill
            * event
            * roles
                * name
                * shortname
            * teachers
                * firstname
                * lastname

    Example context (json):
    {
        "courses": []
    }
}}
<div id="apsolu-enrol-select-presentation">

  <!-- Boite de filtres générée avec javascript. -->

  <!-- Liste des cours. -->
  <div id="apsolu-enrol-select-presentation-courses-list2" class="table-unresponsive">
  {{#courses}}
    {{#url}}<p><a href="{{.}}">Modalités pédagogiques</a></p>{{/url}}
    {{#description}}<div>{{{.}}}</div>{{/description}}

    <table class="table table-bordered table-striped table-sorter2 table-sortable" id="apsolu-enrol-select">
      <thead>
        <tr>
            <th class="col-md-1 hide" data-column="sites">Site</th>
            <th class="col-md-1 hide" data-column="sports">Activité</th>
            <th class="col-md-1" data-column="periods">Période</th>
            <th class="col-md-1" data-column="weekdays">Jour</th>
            <th class="col-md-1" data-column="times">Horaire</th>
            <th class="col-md-2" data-column="areas">Zone géographique</th>
            <th class="col-md-2" data-column="locations">Lieu</th>
            <th class="col-md-1" data-column="skills">Niveau</th>
            <th class="col-md-1" data-column="roles">Type d'inscription</th>
            <th class="col-md-2" data-column="teachers">{{#str}}teachers{{/str}}</th>
        </tr>
      </thead>
      <tbody>
        {{#courses}}
        <tr>
          <td class="hide" data-column="sites" data-value="{{site}}">{{site}}</td>
          <td class="hide" data-column="sports" data-value="{{sport}}">{{sport}}</td>
          <td data-column="periods" data-value="{{generic_name}}">{{generic_name}}</td>
          <td data-column="weekdays" data-value="{{weekday}}">{{weekday}}</td>
          <td data-column="times" data-value="{{time}}">{{starttime}} - {{endtime}}</td>
          <td data-column="areas" data-value="{{area}}">{{area}}</td>
          <td data-column="locations" data-value="{{location}}">{{location}}</td>
          <td data-column="skills" data-value="{{skill}}">{{skill}}{{#event}}<br />({{event}}){{/event}}</td>
          <td data-column="roles">
            <ul class="list-inline2 list-unstyled">
              {{#roles}}
              <li class="apsolu-roles-list-li"><span title="{{name}}" class="apsolu-roles apsolu-roles-{{shortname}}"></span><span class="sr-only2">{{name}}</span></li>
              {{/roles}}
            </ul>
          </td>
          <td data-column="teachers">
            <ul class="list-unstyled">
              {{#teachers}}
              <li class="apsolu-teachers-list-li">{{firstname}} {{lastname}}</li>
              {{/teachers}}
            </ul>
          </td>
        </tr>
        {{/courses}}
      </tbody>
    </table>
  {{/courses}}
  </div>
</div>
